# ─────────────────────────────────────────────────────────────────────────────
# Plantilla de secrets para Ferran
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copia este archivo y guárdalo como:  .streamlit/secrets.toml
# 2. Rellena los valores con tus datos reales.
# 3. ¡NUNCA subas secrets.toml a GitHub! Está protegido por .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

[github]
# Token de acceso personal de GitHub (classic o fine-grained).
# Permiso mínimo necesario: "Contents" → Read & Write sobre este repositorio.
# Crea uno en: https://github.com/settings/tokens
token = "ghp_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# Nombre completo del repositorio en formato "usuario/repositorio"
repo  = "johnbij/ferran"
